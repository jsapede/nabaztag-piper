# Example environment configuration for nabaztag-piper
# Copy to .env and adapt to your setup

# Piper configuration
PIPER_BINARY=/path/to/piper
PIPER_VOICES_FOLDER=/path/to/piper-voices
PIPER_DEFAULT_VOICE=fr_FR-siwis-medium
PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=1.5
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.333
PIPER_VOLUME=1
PIPER_SENTENCE_SILENCE=0.2

# Phonemes (espeak-ng)
PIPER_USE_PHONEMES=true
ESPEAK_BINARY=/usr/bin/espeak-ng
ESPEAK_VOICE=fr

# FFmpeg
FFMPEG_BINARY=/usr/bin/ffmpeg
PIPER_USE_FFMPEG=true
PIPER_TARGET_SAMPLE_RATE=16000
FFMPEG_VOLUME=1.5
FFMPEG_HIGH_PASS=300
FFMPEG_TREBLE=3
