# ═══════════════════════════════════════════════════════════
# Nabaztag Piper — Configuration
# ═══════════════════════════════════════════════════════════
# Copier ce fichier vers GLOBAL_DIR/.env, éditer, puis lancer install/install.sh
#
# Réinstallation : modifier .env et relancer install.sh
# Désinstallation : install.sh --uninstall
# Simulation : install.sh --dry-run

# ─── Dossier global ────────────────────────────────────────
GLOBAL_DIR=/opt/nabaztag-piper

# ─── IP du serveur TTS (obligatoire) ──────────────────────
# Adresse IP de la machine qui fait tourner piper_tts_stream.py.
# Le Nabaztag doit pouvoir joindre cette IP sur le port TTS_PORT.
#
# Par defaut (XXX.XXX.XXX.XXX) : install.sh detecte l'IP de la machine
# et demande confirmation avant de compiler le firmware.
#
# Si le proxy TTS change de machine : modifier ici et relancer install.sh.
TTS_SERVER_IP=XXX.XXX.XXX.XXX
TTS_PORT=6790

# ─── Moteur TTS ───────────────────────────────────────────
TTS_ENGINE=piper                  # piper | coqui

# ─── Piper ────────────────────────────────────────────────
# Explorer les voix : https://huggingface.co/rhasspy/piper-voices/tree/main
# Écouter les samples : https://rhasspy.github.io/piper-samples/
# Exemples :
#   fr/fr_FR/siwis/medium  → voix féminine française
#   fr/fr_FR/gilles/low    → voix masculine française
#   en/en_US/lessac/medium  → voix américaine
PIPER_VOICE_PATH=fr/fr_FR/siwis/medium
PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=1.5
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.333
PIPER_VOLUME=1
PIPER_SENTENCE_SILENCE=0.2
PIPER_USE_PHONEMES=true
ESPEAK_VOICE=fr

# ─── Coqui ────────────────────────────────────────────────
COQUI_MODEL=vits

# ─── Compilation firmware ─────────────────────────────────
BUILD_FIRMWARE=false
ENABLE_WEB_SERVER=false
WEB_SERVER_PORT=80
