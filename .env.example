# Example environment configuration for nabaztag-piper
# Copy to .env and adapt to your setup
#
# Installation:
#   1. cp .env.example .env
#   2. Editer les chemins ci-dessous
#   3. Modifier l'IP du TTS dans vl/hooks.forth (ligne 43)
#   4. Recompiler le firmware: make firmware
#   5. Installer le service: ./install.sh

# ─── TTS Server ──────────────────────────────────────────────────────────
# Adresse du serveur TTS (doit correspondre à vl/hooks.forth)
TTS_SERVER=192.168.0.42
TTS_PORT=6790

# ─── Piper ────────────────────────────────────────────────────────────────
PIPER_BINARY=/root/.local/bin/piper
PIPER_VOICES_FOLDER=/opt/configs/piper
PIPER_DEFAULT_VOICE=fr_FR-siwis-medium
PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=1.5
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.333
PIPER_VOLUME=1
PIPER_SENTENCE_SILENCE=0.2

# ─── Phonemes (espeak-ng) ────────────────────────────────────────────────
PIPER_USE_PHONEMES=true
ESPEAK_BINARY=/usr/bin/espeak-ng
ESPEAK_VOICE=fr

# ─── FFmpeg ──────────────────────────────────────────────────────────────
FFMPEG_BINARY=/usr/bin/ffmpeg
PIPER_USE_FFMPEG=true
PIPER_TARGET_SAMPLE_RATE=16000
FFMPEG_VOLUME=1.5
FFMPEG_HIGH_PASS=300
FFMPEG_TREBLE=3

# ─── Deploy ──────────────────────────────────────────────────────────────
# Cible pour `make deploy` (user@host:/path)
# DEPLOY_TARGET=root@192.168.0.58:/opt/New_Serverless_v3/
